// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model LastUpdate {
  id        Int      @id @default(1)
  updatedAt DateTime @default(now())

  @@map("last_update") // maps table name to snake_case
}

model Active {
  date                   DateTime @id @db.Date
  active_based_on_pp     Int
  active_based_on_in_use Int

  @@map("active")
}

model ResourceSupply {
  date         DateTime @db.Date
  resource     String
  total_supply BigInt

  @@id([date, resource])
  @@map("resource_supply")
}

model ResourceTracking {
  date                    DateTime @db.Date
  token_symbol            String
  total_harvest_pp        Float
  total_base_pp_after_cap Float
  rewards_per_hour        Float?
  cost_per_h_grain        Float?
  cost_per_h_wood         Float?
  cost_per_h_stone        Float?
  cost_per_h_iron         Float?

  @@id([date, token_symbol])
  @@map("resource_tracking")
}

model ResourceHubMetrics {
  date               DateTime @db.Date
  id                 Int
  token_symbol       String
  resource_quantity  String
  resource_volume    Float
  resource_volume_1  Float?
  resource_volume_30 Float?
  resource_price     Float
  dec_quantity       String
  dec_volume         Float
  dec_volume_1       Float?
  dec_volume_30      Float?
  total_shares       String
  created_date       DateTime
  last_updated_date  DateTime

  // Added By myself
  dec_price        Float
  dec_usd_value    Float
  grain_equivalent Float
  factor           Float

  @@id([date, token_symbol])
  @@map("resource_hub_metrics")
}

model PlayerProductionSummary {
  player                  String @id
  total_harvest_pp        Float
  total_base_pp_after_cap Float
  count                   Int
  total_dec               Float
  dec_grain               Float  @default(0)
  dec_wood                Float  @default(0)
  dec_stone               Float  @default(0)
  dec_iron                Float  @default(0)
  dec_research            Float  @default(0)
  dec_aura                Float  @default(0)
  dec_sps                 Float  @default(0)

  @@map("player_production_summary")
}

model Deed {
  deed_uid                 String    @id
  map_name                 String
  region_id                Int
  tract_id                 Int
  plot_id                  Int
  region_number            Int
  tract_number             Int
  plot_number              Int
  territory                String
  region_uid               String
  resource_id              Int?
  resource_symbol          String?
  magic_type               String?
  stats                    Json?
  player                   String?
  created_date             DateTime?
  listed                   Boolean?
  lock_days                Int?
  unlock_date              DateTime?
  in_use                   Boolean?
  deed_type                String?
  land_stats               Json?
  region_name              String?
  market_updated_date      DateTime?
  market_id                String?
  listing_price            String?
  market_listing_id        String?
  market_listing_status_id Int?
  castle                   Int?
  keep                     Int?
  rarity                   String?
  plot_status              String?
  hex_code                 String?
  tax_rate                 String?
  item_detail_id           Int?
  created_block_num        Int?
  created_tx               String?
  worksite_type            String?
  time_crystal_value       Int?
  rarity_sort_value        Int?
  is_construction          Boolean?

  worksiteDetail WorksiteDetail?
  stakingDetail  StakingDetail?

  @@map("deed")
}

model WorksiteDetail {
  deed_uid                                  String    @id
  token_symbol                              String
  id                                        Int
  project_type                              String?
  project_number                            Int?
  land_work_type_id                         Int?
  total_time_crystals_used                  Float?
  pp_balance                                Float?
  start_date                                DateTime?
  projected_hours                           Float?
  projected_end                             DateTime?
  completed_date                            DateTime?
  created_date                              DateTime?
  last_updated_date                         DateTime?
  trx_id                                    String?
  block_num                                 Int?
  resource_id                               Int?
  pp_required                               Float?
  hours_to_completion                       Float?
  elapsed_hours                             Float?
  pp_spent                                  Float?
  grain_required                            Float?
  wood_required                             Float?
  stone_required                            Float?
  iron_required                             Float?
  is_active                                 Boolean?
  destroyed_date                            DateTime?
  is_construction                           Boolean?
  last_action_time                          DateTime?
  hours_till_next_op                        Float?
  next_op_allowed_date                      DateTime?
  pp_staked                                 Float?
  projected_amount_received                 Float?
  work_per_hour_per_one_pp                  Float?
  project_id                                Int?
  is_harvesting                             Boolean?
  is_empty                                  Boolean?
  is_sps_work                               Boolean?
  sps_mining_reward_debt                    Float?
  latest_sps_reward_block                   Float?
  sps_tokens_per_block                      Float?
  accumulated_sps_rewards_per_share_of_pool Float?
  land_work_type_total_work_type_pp         Float?
  captured_tax_rate                         Float?
  time_crystal_value                        Int?
  project_created_date                      DateTime?
  worksite_type                             String?
  max_tax_rate                              Float?
  region_uid                                String?
  hours_since_last_op                       Float?
  site_efficiency                           Float?
  is_runi_staked                            Boolean?
  rewards_per_hour                          Float?
  grain_req_per_hour                        Float?
  segments                                  Json?
  estimated_totem_chance                    Float?
  resource_recipe                           Json?
  resource_mint_rate                        Float?

  deed Deed @relation(fields: [deed_uid], references: [deed_uid], onDelete: Cascade)

  @@map("worksite_detail")
}

model StakingDetail {
  deed_uid                           String   @id
  region_uid                         String?
  is_powered                         Boolean?
  is_runi_staked                     Boolean?
  is_power_core_staked               Boolean?
  is_energized                       Boolean?
  has_labors_luck                    Boolean?
  max_workers_allowed                Int?
  runi_boost                         Float?
  title_boost                        Float?
  totem_boost                        Float?
  deed_status_token_boost            Float?
  deed_rarity_boost                  Float?
  card_abilities_boost               Float?
  card_bloodlines_boost              Float?
  grain_food_discount                Float?
  dec_stake_needed_discount          Float?
  total_boost                        Float?
  total_base_pp_cap                  Float?
  total_base_pp                      Float?
  total_base_pp_after_cap            Float?
  total_base_pp_after_cap_percentage Float?
  total_construction_pp              Float?
  total_terrain_boost                Float?
  total_terrain_boost_pp             Float?
  total_dec_stake_needed             Float?
  total_dec_stake_in_use             Float?
  efficiency                         Float?
  total_deed_rarity_boost            Float?
  total_deed_rarity_boost_pp         Float?
  total_deed_status_token_boost      Float?
  total_deed_status_token_boost_pp   Float?
  total_runi_boost                   Float?
  total_runi_boost_pp                Float?
  total_title_boost                  Float?
  total_title_boost_pp               Float?
  total_totem_boost                  Float?
  total_totem_boost_pp               Float?
  total_card_abilities_boost_pp      Float?
  total_card_bloodlines_boost_pp     Float?
  total_boost_pp                     Float?
  total_harvest_pp                   Float?
  total_work_per_hour                Float?
  powered_worker_count               Int?
  worker_count                       Int?
  manager                            String?
  active_land_project_id             Int?
  has_completed_first_project        Boolean?
  red_biome_modifier                 Float?
  blue_biome_modifier                Float?
  white_biome_modifier               Float?
  black_biome_modifier               Float?
  green_biome_modifier               Float?
  gold_biome_modifier                Float?
  total_dec_staked                   Float?

  deed Deed @relation(fields: [deed_uid], references: [deed_uid], onDelete: Cascade)

  @@map("staking_detail")
}

model PlayerTradeHubPosition {
  date                        DateTime @db.Date
  player                      String
  token                       String   // DEC-GRAIN
  balance                     Float
  total_fees_earned_dec       Float
  total_fees_earned_resource  Float
  fees_earned_dec_1           Float
  fees_earned_resource_1      Float
  fees_earned_dec_30          Float
  fees_earned_resource_30     Float

  share_percentage            Float   // calculated as balance / ResourceHubMetrics.totalShares * 100
  resource_quantity           Float
  dec_quantity                Float

  @@id([date, player, token])
  @@map("player_trade_hub_position")

}

model DailyBurnedTokenBalance {
  date         DateTime @db.Date
  player       String
  token        String
  balance      Decimal  @db.Decimal(30, 6)

  @@id([date, player, token])
  @@map("daily_burned_token_balance")
}

model PlayerCardEditionSummary {
  date               DateTime @db.Date
  player             String
  card_set           String   // e.g. "chaos", "alpha", "rebellion"
  total_cards        Int
  foil_regular       Int
  foil_gold          Int      // foil type 1
  foil_gold_arcane   Int      // foil type 2
  foil_black         Int      // foil type 3
  foil_black_arcane  Int      // foil type 4
  land_base_pp       Int
  owned              Int
  rented             Int
  delegated          Int
  rarity_level_counts Json   // { "common": { "1": { "regular": 5, "gold arcane": 2 }, "2": {} }, "rare": { ... } }

  @@id([date, player, card_set])
  @@map("player_card_edition_summary")
}

model WorkerRun {
  id          String    @id @default(cuid())
  job_type    String    // "daily" | "weekly"
  status      String    // "running" | "completed" | "failed"
  started_at  DateTime  @default(now())
  finished_at DateTime?
  duration_ms Int?
  error       String?

  @@map("worker_run")
}

model Log {
  id        String   @id @default(cuid())
  level     String   // "info" | "warn" | "error"
  message   String
  meta      Json?
  created_at DateTime @default(now())

  @@index([level])
  @@index([created_at])
  @@map("logs")
}

model LandStakeDecLog {
  date             DateTime @db.Date
  player           String
  runs             Int      @default(1)
  succeeded_json   Json     @default("{}")    // { region_uid: amount } broadcast & confirmed
  failed_json      Json     @default("{}")    // { region_uid: amount } attempted but failed
  total_succeeded  Float    @default(0)
  total_failed     Float    @default(0)
  error            String?
  transactions     String[] @default([])
  updated_at       DateTime @updatedAt

  @@id([date, player])
  @@map("land_stake_dec_log")
}

model LandManagerConfig {
  player                          String   @id
  enabled_regions                 Int[]
  make_harvestable_strategies     String[] @default(["transfer", "swap", "buy_dec"])
  donation_enabled                Boolean  @default(true)
  donation_pct                    Int      @default(2)
  donation_daily_caps_json        Json     @default("{\"GRAIN\":40000,\"WOOD\":10000,\"STONE\":4000,\"IRON\":1000}")
  post_harvest_strategy           String   @default("accumulate")
  post_harvest_excluded_resources String[] @default([])
  post_harvest_sell_pct           Int      @default(0)
  post_harvest_pool_pct           Int      @default(100)
  rental_strategy                   String  @default("highest_pp_per_dec")
  rental_max_total_dec              Int     @default(0)
  rental_max_dec_per_day_per_worker Int     @default(0)
  rental_min_land_base_pp           Int     @default(0)
  rental_min_foil                   Int     @default(0)
  rental_batch_size                 Int?    @default(10)
  rental_land_renters_only          Boolean @default(false)
  created_at                      DateTime @default(now())
  updated_at                      DateTime @updatedAt

  @@map("land_manager_config")
}

model LandHarvestLog {
  date                 DateTime @db.Date
  player               String
  runs                 Int      @default(1)
  resources_json       Json     // { GRAIN: total, WOOD: total, … } summed across all runs today
  donations_json       Json     @default("{}")  // { GRAIN: donationTotal, … } donations successfully paid
  unpaid_donations_json Json    @default("{}")  // { GRAIN: donationTotal, … } donations owed but not paid (cancelled/failed)
  donation_error       String?                  // last error or cancellation reason when unpaid_donations_json is non-empty
  harvest_transactions String[]                 // txIds from the harvest phase
  donation_transactions String[] @default([])   // txIds from the donation-payment phase
  updated_at           DateTime @updatedAt

  @@id([date, player])
  @@map("land_harvest_log")
}

model LandMakeHarvestableLog {
  date         DateTime @db.Date
  player       String
  runs         Int      @default(1)
  actions_json Json     // array of ActionSummary, merged/summed by (type,from_region,to_region,from_symbol,to_symbol)
  transactions String[] // one txId per successful broadcast
  updated_at   DateTime @updatedAt

  @@id([date, player])
  @@map("land_make_harvestable_log")
}

model LandPostHarvestLog {
  date         DateTime @db.Date
  player       String
  runs         Int      @default(1)
  actions_json Json     // array of PostHarvestActionSummary, merged by (type, region_uid, symbol)
  transactions String[]
  updated_at   DateTime @updatedAt

  @@id([date, player])
  @@map("land_post_harvest_log")
}

model LandMythicHarvestLog {
  date              DateTime @db.Date
  player            String
  runs              Int      @default(1)
  results_json      Json                     // array of MythicHarvestResult
  donations_json    Json     @default("{}")  // { token: total } donations successfully paid
  unpaid_donations_json Json @default("{}")  // { token: total } donations owed but not paid
  donation_error    String?                  // last donation error or cancellation reason
  transactions      String[]                 // txIds from tax_collection ops
  donation_transactions String[] @default([]) // txIds from donation-payment ops
  updated_at        DateTime @updatedAt

  @@id([date, player])
  @@map("land_mythic_harvest_log")
}

model LandRentalLog {
  date               DateTime @db.Date
  player             String
  runs               Int      @default(1)
  rented_count       Int      @default(0)   // total cards rented across all runs today
  staked_count       Int      @default(0)   // total cards staked across all runs today
  total_dec          Float    @default(0)   // total DEC spent across all runs today
  rent_transactions  String[] @default([])  // txIds from sm_market_rent ops
  stake_transactions String[] @default([])  // txIds from staking ops
  updated_at         DateTime @updatedAt

  @@id([date, player])
  @@map("land_rental_log")
}
