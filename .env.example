# =============================================================================
# Splinter Lands — environment variable reference
# Copy to `.env` (or `.env.local`) and fill in the values you need.
# =============================================================================

# --- Database ----------------------------------------------------------------
# Required — docker-compose.yml no longer ships defaults for these.
# Choose strong values; the deploy will fail fast if any are missing.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=spl
# Required for both `next dev` and `npm run worker`.
DATABASE_URL="postgresql://postgres:postgres@localhost:54332/spl"

# --- NextAuth (GitHub OAuth) -------------------------------------------------
# Public URL of the app — used by NextAuth for callback URLs.
NEXTAUTH_URL="http://localhost:3000"
# Secret used to sign NextAuth sessions. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-at-least-32-chars"
# --- GitHub OAuth ------------------------------------------------------------
# Create an OAuth App at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=your-github-oauth-app-id
GITHUB_SECRET=your-github-oauth-app-secret
# --- Access control ----------------------------------------------------------
# Comma-separated GitHub usernames that are allowed to sign in
GITHUB_ALLOWED_USERS="your-github-username"

# --- Cache invalidation -----------------------------------------------------
# Shared secret for POST /api/cache/refresh. The worker uses the same token
# to trigger cache refreshes via NEXT_PUBLIC_BASE_URL.
CACHE_INVALIDATE_TOKEN="change-me"
# Base URL the worker hits when refreshing the cache.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# --- App metadata -----------------------------------------------------------
# Optional version label rendered on the admin page. Falls back to "dev".
# APP_VERSION="1.0.0"

# --- Service-fee exemptions -------------------------------------------------
# Comma-separated lists. Values are MERGED with the built-in defaults
# These are SERVER-ONLY env vars (no NEXT_PUBLIC_ prefix) — the exemption
# list is never bundled into the client JS.
# FEE_EXEMPT_USERS=otheruser1,otheruser2
# FEE_EXEMPT_REGIONS=70,80


# ──────────────────────────────────────────────────────────────────────────────
# Rental Authority (required for Rent Empty Workers)
#
# Renting is server-side only: the configured account signs `sm_market_rent`
# from its active key on behalf of any player who has granted it the "rental"
# authority via https://splinterlands.com/user/account-security.
#
# Without these set, the Rent Empty Workers buttons stay disabled (and the
# Land Manager page shows a warning card explaining the missing config).
# Posting-key ops (worker staking) still use the player's Hive Keychain.
# ──────────────────────────────────────────────────────────────────────────────
# The Hive account that signs delegated rent ops (server-side only).
SPL_LAND_SERVICE_ACCOUNT=
# The active private key for the account above. NEVER expose to the browser.
SPL_LAND_SERVICE_ACTIVE_KEY=
# Optional: comma-separated Hive RPC endpoints used by @hiveio/dhive.
# Defaults to api.hive.blog, api.openhive.network, api.deathwing.me.
HIVE_RPC_NODES=
